    "/API/v3/CameraController/GetPreview/{cameraId}": {
      "get": {
        "tags": [
          "Camera"
        ],
        "summary": "Returns the latest preview image (as raw bytes) for the specified camera.",
        "parameters": [
          {
            "name": "cameraId",
            "in": "path",
            "description": "The unique identifier of the camera whose preview should be retrieved.",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "X-AccessToken",
            "in": "header",
            "description": "Access Token",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "text/plain": {
                "schema": {
                  "type": "string",
                  "format": "byte"
                }
              },
              "application/json": {
                "schema": {
                  "type": "string",
                  "format": "byte"
                }
              },
              "text/json": {
                "schema": {
                  "type": "string",
                  "format": "byte"
                }
              }
            }
          }
        }
      }
    },
