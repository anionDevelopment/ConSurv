  "components": {
    "schemas": {
      "AccessToken": {
        "type": "object",
        "properties": {
          "ownerUserId": {
            "type": "string",
            "nullable": true
          },
          "value": {
            "type": "string",
            "nullable": true
          },
          "expiredMoment": {
            "type": "string",
            "format": "date-time"
          }
        },
        "additionalProperties": false
      },
      "CameraDTO": {
        "type": "object",
        "properties": {
          "cameraId": {
            "type": "string",
            "nullable": true
          },
          "name": {
            "type": "string",
            "nullable": true
          },
          "videoInformationDTO": {
            "$ref": "#/components/schemas/VideoInformationDTO"
          },
          "recordModeDTO": {
            "$ref": "#/components/schemas/RecordModeDTO"
          },
          "recordStateDTO": {
            "$ref": "#/components/schemas/RecordStateDTO"
          }
        },
        "additionalProperties": false,
        "description": "Data transfer object that exposes the full observable state of a camera to clients,\r\ncombining its identity, video source, recording configuration, and current record state."
      },
      "ONVIFCommandDTO": {
        "type": "object",
        "properties": {
          "commandType": {
            "type": "string",
            "nullable": true
          },
          "direction": {
            "type": "string",
            "nullable": true
          }
        },
        "additionalProperties": false,
        "description": "Data transfer object used to deserialize an ONVIF PTZ command received from a client.\r\nThe ConSurvBackend.Core.Model.DTOs.ONVIFCommandDTO.CommandType discriminator selects the concrete ConSurvBackend.Core.Model.SpecialFunctions.ONVIF.Commands.ONVIFCommand subtype."
      },
      "RecordModeDTO": {
        "type": "object",
        "properties": {
          "recordMode": {
            "type": "string",
            "nullable": true
          }
        },
        "additionalProperties": false,
        "description": "Data transfer object that encodes a ConSurvBackend.Core.Model.RecordModes.RecordMode as its type name\r\nfor serialization and deserialization across the API boundary."
      },
      "RecordStateDTO": {
        "type": "object",
        "properties": {
          "recordState": {
            "type": "string",
            "nullable": true
          }
        },
        "additionalProperties": false,
        "description": "Data transfer object that encodes the current ConSurvBackend.Core.Model.RecordStates.RecordState of a camera\r\nas its type name for transport over the API."
      },
      "UpdateCameraDTO": {
        "type": "object",
        "properties": {
          "cameraId": {
            "type": "string",
            "nullable": true
          },
          "name": {
            "type": "string",
            "nullable": true
          },
          "videoInformationDTO": {
