    "/API/v3/StreamingController/Stream/{streamId}/{filename}": {
      "get": {
        "tags": [
          "Streaming"
        ],
        "summary": "Serves an HLS stream segment or playlist file for the specified stream.\r\nValidates the filename format, resolves the file from the camera's fragment folder,\r\nand returns it with the appropriate MIME type (`application/vnd.apple.mpegurl` for\r\n`.m3u8` playlists, `video/MP2T` for `.ts` segments).",
        "parameters": [
          {
            "name": "streamId",
            "in": "path",
            "description": "The identifier of the stream (typically a camera ID).",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "filename",
            "in": "path",
            "description": "The HLS segment or playlist filename to serve (must match `^[0-9A-Za-z_]+\\.[0-9A-Za-z]+$`).",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "X-AccessToken",
            "in": "header",
            "description": "Access Token",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    },
