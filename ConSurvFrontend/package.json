{
  "name": "continuous-surveillance",
  "version": "1.0.0",
  "scripts": {
    "build": "npm run build-QualityCheck",
    "build-Development": "ng build --configuration Development",
    "build-QualityCheck": "ng build --configuration QualityCheck",
    "build-Productive": "ng build --configuration Productive",
    "test": "npm run test-QualityCheck",
    "test-Development": "ng test --configuration Development --browsers ChromeHeadless --code-coverage --watch false",
    "test-QualityCheck": "ng test --configuration QualityCheck --browsers ChromeHeadless --code-coverage --watch false",
    "test-Productive": "ng test --configuration Productive --browsers ChromeHeadless --code-coverage --watch false",
    "generate-api-client": "openapi-generator-cli generate -g typescript-angular -i ./Other/Resources/DependentCodeUnits/ConSurvBackend/APISpecification/ConSurvBackend.latest.api.json -o ./src/app/generated/con-surv-backend",
    "start": "ng serve --configuration Development"
  },
  "private": true,
  "dependencies": {
    "@angular/animations": "18.1.1",
    "@angular/cdk": "18.1.1",
    "@angular/common": "18.1.1",
    "@angular/compiler": "18.1.1",
    "@angular/core": "18.1.1",
    "@angular/forms": "18.1.1",
    "@angular/material": "18.1.1",
    "@angular/platform-browser": "18.1.1",
    "@angular/platform-browser-dynamic": "18.1.1",
    "@angular/router": "18.1.1",
    "rxjs": "7.8.1",
    "zone.js": "0.14.8"
  },
  "devDependencies": {
    "@angular-devkit/build-angular": "18.1.1",
    "@angular-eslint/builder": "18.1.0",
    "@angular-eslint/eslint-plugin": "18.1.0",
    "@angular-eslint/eslint-plugin-template": "18.1.0",
    "@angular-eslint/schematics": "18.1.0",
    "@angular-eslint/template-parser": "18.1.0",
    "@angular/cli": "18.1.1",
    "@angular/compiler-cli": "18.1.1",
    "@types/jasmine": "5.1.4",
    "@typescript-eslint/eslint-plugin": "7.16.1",
    "@typescript-eslint/parser": "7.16.1",
    "eslint": "9.7.0",
    "jasmine-core": "5.2.0",
    "karma": "6.4.3",
    "karma-chrome-launcher": "3.2.0",
    "karma-coverage": "2.2.1",
    "karma-jasmine": "5.1.0",
    "karma-jasmine-html-reporter": "2.1.0",
    "openapi-typescript-codegen": "0.29.0",
    "tslib": "2.8.1",
    "typescript": "5.5.3"
  }
}