{
  "name": "con-surv-frontend",
  "version": "3.0.10",
  "scripts": {
    "build": "npm run build-QualityCheck",
    "build-Development": "ng build --localize --configuration Development",
    "build-QualityCheck": "ng build --localize --configuration QualityCheck",
    "build-Productive": "ng build --localize --configuration Productive",
    "test": "npm run test-QualityCheck",
    "test-Development": "ng test --configuration Development --browsers ChromeHeadless --watch false",
    "test-QualityCheck": "ng test --configuration QualityCheck --browsers ChromeHeadless --watch false",
    "test-Productive": "ng test --configuration Productive --browsers ChromeHeadless --watch false",
    "start": "ng serve --configuration Development --host 0.0.0.0 --live-reload=false --disable-host-check",
    "lint": "ng lint"
  },
  "dependencies": {
    "@angular/animations": "19.2.0",
    "@angular/cdk": "19.2.1",
    "@angular/common": "19.2.0",
    "@angular/compiler": "19.2.0",
    "@angular/core": "19.2.0",
    "@angular/forms": "19.2.0",
    "@angular/material": "19.2.1",
    "@angular/platform-browser": "19.2.0",
    "@angular/localize": "19.2.0",
    "@angular/platform-browser-dynamic": "19.2.0",
    "@angular/router": "19.2.0",
    "rxjs": "7.8.2",
    "tslib": "2.8.1",
    "video.js": "8.23.3",
    "zone.js": "0.15.1"
  },
  "devDependencies": {
    "@angular-devkit/build-angular": "19.2.0",
    "@angular/cli": "19.2.0",
    "@angular/compiler-cli": "19.2.0",
    "@types/jasmine": "5.1.7",
    "angular-eslint": "19.2.0",
    "eslint": "9.21.0",
    "jasmine-core": "5.6.0",
    "karma": "6.4.4",
    "karma-chrome-launcher": "3.2.0",
    "karma-coverage": "2.2.1",
    "karma-jasmine": "5.1.0",
    "karma-jasmine-html-reporter": "2.1.0",
    "typescript": "5.8.2",
    "typescript-eslint": "8.15.0"
  }
}